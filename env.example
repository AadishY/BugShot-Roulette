# ==========================================
# CLIENT (Vite Front-end) Environment Variables
# ==========================================
VITE_DEV_USERNAME=your_dev_username
VITE_DEV_PASSWORD=your_dev_password
VITE_DISCORD_CLIENT_ID=your_discord_client_id
VITE_SERVER_URL=your_backend_server_url
VITE_UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
VITE_UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ==========================================
# SERVER (Node/Express) Environment Variables
# ==========================================
PORT=3001
DEV_USERNAME=your_dev_username
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
ALLOWED_ORIGINS=https://your-frontend-domain.com